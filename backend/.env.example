# CoBug AI Learning Platform - Backend Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Groq API key (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: GitHub personal access token
# Increases GitHub API rate limit from 60 to 5000 req/hr
# Get one at https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=your_github_token_here

# Optional: Port for the backend server (default: 5000)
PORT=5000
